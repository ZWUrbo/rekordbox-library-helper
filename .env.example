REKORDBOX_XML_PATH=/path/to/rekordbox.xml
SQLITE_DB_PATH=data/rekordbox_tracks.sqlite3
LOG_LEVEL=INFO

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_MARKET=US
SPOTIFY_MINIMUM_MATCH_SCORE=0.75
SPOTIFY_SEARCH_LIMIT=3
SPOTIFY_RPS=2.0

RAPIDAPI_DJ_AUDIO_ANALYSIS_KEY=
RAPIDAPI_DJ_AUDIO_ANALYSIS_HOST=dj-track-audio-analysis-api.p.rapidapi.com
RAPIDAPI_DJ_AUDIO_ANALYSIS_PATH=/tracks/audio-analysis
RAPIDAPI_DJ_AUDIO_ANALYSIS_IDS_PARAM=ids
RAPIDAPI_DJ_AUDIO_ANALYSIS_RPS=2.0
